# =============================================================================
# 환경변수 템플릿 (.env.example)
# =============================================================================
# 이 파일을 복사하여 .env 파일을 생성하세요:
#   Windows : copy .env.example .env
#   Mac/Linux : cp .env.example .env
#
# .env 파일은 .gitignore에 의해 Git에 올라가지 않습니다.
# 절대 실제 키 값을 이 파일(.env.example)에 넣지 마세요!
#
# 주의사항:
#   - 값에 따옴표("")를 사용하지 마세요 (python-dotenv가 따옴표를 값에 포함시킵니다)
#     (O) SUPABASE_KEY=eyJhbGciOi...
#     (X) SUPABASE_KEY="eyJhbGciOi..."
#   - '=' 앞뒤에 공백을 넣지 마세요
#     (O) SUPABASE_URL=https://xxx.supabase.co
#     (X) SUPABASE_URL = https://xxx.supabase.co
# =============================================================================


# =============================================================================
# 1. Supabase 설정 (필수)
# =============================================================================
# 용도: 사용자 인증, 영수증 데이터 저장, 이미지 스토리지
# 확인 방법:
#   1) https://supabase.com 로그인
#   2) 프로젝트 선택
#   3) Settings > API 메뉴 이동
#   4) Project URL → SUPABASE_URL에 입력
#   5) anon public 키 → SUPABASE_KEY에 입력
# =============================================================================

SUPABASE_URL=https://your-project-id.supabase.co
SUPABASE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.your-anon-key-here

# =============================================================================
# 2. Supabase Storage 버킷 이름 (선택)
# =============================================================================
# 용도: 영수증 이미지를 업로드할 Storage 버킷 이름
# 확인 방법:
#   1) Supabase 대시보드 > Storage 메뉴
#   2) 사용할 버킷 이름 확인 (없으면 새로 생성)
#   3) 버킷의 Public 설정이 활성화되어 있어야 이미지 미리보기 가능
# 기본값: 설정하지 않으면 "OcrReceipts" 사용
# =============================================================================

SUPABASE_BUCKET=OcrReceipts

# =============================================================================
# 3. Google Cloud Vision OCR 설정 (필수)
# =============================================================================
# 용도: 영수증 이미지에서 텍스트를 추출하는 OCR 엔진
# 확인 방법:
#   1) https://console.cloud.google.com 접속
#   2) 프로젝트 선택 (또는 새 프로젝트 생성)
#   3) API 및 서비스 > 라이브러리 > "Cloud Vision API" 검색 후 사용 설정
#   4) API 및 서비스 > 사용자 인증 정보 > 서비스 계정 생성
#   5) 서비스 계정 > 키 > JSON 키 생성 후 다운로드
#   6) 다운로드한 JSON 파일을 프로젝트 내 원하는 위치에 저장
#   7) 해당 파일 경로를 GOOGLE_APPLICATION_CREDENTIALS에 입력
#
# 경로 예시:
#   Windows : ./config/secrets/api_key.json (상대경로)
#   절대경로 : C:/Users/user/keys/api_key.json
# =============================================================================

GOOGLE_APPLICATION_CREDENTIALS=./config/secrets/api_key.json

# =============================================================================
# 4. Gemini AI 설정 (선택 - AI 조언 기능 사용 시 필수)
# =============================================================================
# 용도: 월별 지출 내역을 AI가 분석하여 소비 패턴 및 절약 조언 제공
# 확인 방법:
#   1) https://aistudio.google.com/apikey 접속
#   2) Google 계정으로 로그인
#   3) "Create API Key" 버튼 클릭
#   4) 생성된 API Key를 복사하여 아래에 입력
#
# 참고:
#   - 무료 티어로도 사용 가능 (분당 요청 수 제한 있음)
#   - 이 키가 없어도 OCR, 저장, 분석 차트 등 핵심 기능은 정상 동작
#   - AI 조언 버튼을 누를 때만 사용됨
# =============================================================================

GEMINI_API_KEY=your-gemini-api-key-here


# =============================================================================
# [Streamlit Community Cloud 배포 시 참고]
# =============================================================================
# Streamlit 서버에서는 .env 파일 대신 Secrets 기능을 사용합니다.
#
# 설정 방법:
#   1) https://share.streamlit.io 에서 앱 배포
#   2) 앱 설정(⚙️) > Secrets 메뉴
#   3) 아래 TOML 형식으로 입력 (Secrets에서는 따옴표 필수!)
#
# ─── Secrets 입력 예시 (TOML 형식) ───────────────────────────
#
#   SUPABASE_URL = "https://your-project-id.supabase.co"
#   SUPABASE_KEY = "eyJhbGciOi..."
#   SUPABASE_BUCKET = "OcrReceipts"
#   GEMINI_API_KEY = "your-gemini-api-key"
#
#   [gcp_service_account]
#   type = "service_account"
#   project_id = "your-project-id"
#   private_key_id = "your-key-id"
#   private_key = "-----BEGIN PRIVATE KEY-----\nMIIEv...\n-----END PRIVATE KEY-----\n"
#   client_email = "xxx@xxx.iam.gserviceaccount.com"
#   client_id = "123456789"
#   auth_uri = "https://accounts.google.com/o/oauth2/auth"
#   token_uri = "https://oauth2.googleapis.com/token"
#   auth_provider_x509_cert_url = "https://www.googleapis.com/oauth2/v1/certs"
#   client_x509_cert_url = "https://www.googleapis.com/robot/v1/metadata/x509/..."
#
# ─────────────────────────────────────────────────────────────
# [gcp_service_account] 섹션:
#   - 로컬의 JSON 키 파일 내용을 TOML 형식으로 그대로 옮겨 적으면 됩니다
#   - 코드가 자동으로 Secrets에서 읽어 임시 JSON 파일을 생성합니다
#   - GOOGLE_APPLICATION_CREDENTIALS 환경변수는 설정하지 않아도 됩니다
# =============================================================================